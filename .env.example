# ─────────────────────────────────────────
# VideoNova Studio — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# NE JAMAIS COMMITER .env.local sur GitHub
# ─────────────────────────────────────────

# Base de données PostgreSQL
DATABASE_URL="postgresql://postgres:motdepasse@localhost:5432/videonova_dev"

# Auth.js / NextAuth
NEXTAUTH_SECRET="generer-un-secret-fort-avec-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Redis (pour BullMQ et les files d'export)
REDIS_URL="redis://localhost:6379"

# Stockage S3 compatible (MinIO en dev, Scaleway/Cloudflare en prod)
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET="videonova-uploads"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_REGION="eu-west-1"
S3_PUBLIC_URL="http://localhost:9000/videonova-uploads"

# Stripe (paiement — Phase 7)
STRIPE_SECRET_KEY="sk_test_votre_cle_stripe"
STRIPE_WEBHOOK_SECRET="whsec_votre_webhook_secret"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_votre_cle_publique"

# OpenAI (IA — Phase 5)
OPENAI_API_KEY="sk-votre-cle-openai"

# ElevenLabs (voix IA — Phase 5)
ELEVENLABS_API_KEY="votre-cle-elevenlabs"

# Limites d'upload
MAX_UPLOAD_SIZE_MB="500"
MAX_VIDEO_DURATION_SECONDS="3600"

# Chemins de stockage local (développement)
UPLOAD_DIR="./public/uploads"
EXPORT_STORAGE_PATH="./public/exports"

# FFmpeg (chemin vers l'exécutable si nécessaire)
FFMPEG_PATH="/usr/bin/ffmpeg"
FFPROBE_PATH="/usr/bin/ffprobe"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="VideoNova Studio"

# Limites du plan gratuit
FREE_PLAN_MAX_PROJECTS="5"
FREE_PLAN_MAX_EXPORTS_PER_MONTH="3"
FREE_PLAN_MAX_STORAGE_MB="500"
FREE_PLAN_MAX_VIDEO_DURATION="120"
FREE_PLAN_WATERMARK="true"

# Limites du plan premium
PREMIUM_PLAN_MAX_PROJECTS="100"
PREMIUM_PLAN_MAX_EXPORTS_PER_MONTH="50"
PREMIUM_PLAN_MAX_STORAGE_MB="10000"
PREMIUM_PLAN_MAX_VIDEO_DURATION="3600"
PREMIUM_PLAN_WATERMARK="false"
